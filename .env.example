# ============================================================
# Vela at Home — environment variables
# Copy this file to .env and fill in all values.
# Run scripts/gen-secrets.sh to populate the secret fields.
# ============================================================


# ── Instance URLs ────────────────────────────────────────────
# Public URL of the Vela server — used for OAuth callback and worker registration.
VELA_ADDR=https://vela.prettybird.zapplebee.online

# Public URL of the Vela UI.
VELA_WEBUI_ADDR=https://vela.prettybird.zapplebee.online

# URL the UI's browser JS uses to reach the API. Must match VELA_ADDR.
VELA_API=https://vela.prettybird.zapplebee.online


# ── GitHub OAuth App ─────────────────────────────────────────
# Create at: https://github.com/settings/applications/new
# Homepage URL:        https://vela.prettybird.zapplebee.online
# Callback URL:        https://vela.prettybird.zapplebee.online/authenticate
# See docs/github-oauth.md for step-by-step instructions.
SCM_CLIENT=
SCM_SECRET=


# ── Database ─────────────────────────────────────────────────
DATABASE_PASSWORD=
DATABASE_ADDR=postgres://vela:REPLACE_WITH_DATABASE_PASSWORD@postgres:5432/vela?sslmode=disable

# AES-256 key for encrypting sensitive values at rest (32 hex chars).
DATABASE_ENCRYPTION_KEY=


# ── Cache ────────────────────────────────────────────────────
CACHE_INSTALL_TOKEN_KEY=


# ── Queue signing keypair ────────────────────────────────────
# Ed25519 keypair — must match between server and worker.
QUEUE_PRIVATE_KEY=
QUEUE_PUBLIC_KEY=


# ── Shared secrets ───────────────────────────────────────────
VELA_SHARED_SECRET=
VELA_SERVER_PRIVATE_KEY=

# These must equal VELA_SHARED_SECRET — do not rename them.
VELA_SECRET=REPLACE_WITH_VELA_SHARED_SECRET
VELA_SERVER_SECRET=REPLACE_WITH_VELA_SHARED_SECRET
