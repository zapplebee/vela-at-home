# ============================================================
# Vela at Home — environment variables
# Copy this file to .env and fill in all values.
# Run scripts/gen-secrets.sh to populate the secret fields.
# ============================================================


# ── Instance URLs ────────────────────────────────────────────
# The public URL of the Vela server API.
# GitHub OAuth will redirect back to this address.
# For Tailscale Funnel exposure:
#   tailscale funnel --bg 3500
#   Then set this to your Tailscale HTTPS hostname + port.
VELA_ADDR=https://nyx.anchovy-scylla.ts.net:3500

# Public URL of the Vela web UI (accessed via Tailscale VPN).
# Can be a local address since users are on Tailscale.
VELA_WEBUI_ADDR=http://nyx:3501

# URL the UI container uses to reach the API (browser-side).
# Must match VELA_ADDR.
VELA_API=https://nyx.anchovy-scylla.ts.net:3500


# ── GitHub OAuth App ─────────────────────────────────────────
# Create at: https://github.com/settings/applications/new
# See docs/github-oauth.md for step-by-step instructions.
SCM_CLIENT=
SCM_SECRET=


# ── Database ─────────────────────────────────────────────────
# Must match POSTGRES_PASSWORD in the postgres service.
# Full connection string used by the server.
DATABASE_PASSWORD=
DATABASE_ADDR=postgres://vela:REPLACE_WITH_DATABASE_PASSWORD@postgres:5432/vela?sslmode=disable

# AES-256 key for encrypting sensitive values at rest (32 hex chars).
DATABASE_ENCRYPTION_KEY=


# ── Cache ────────────────────────────────────────────────────
# Token used to scope install tokens in the cache (64 hex chars).
CACHE_INSTALL_TOKEN_KEY=


# ── Queue signing keypair ────────────────────────────────────
# Ed25519 keypair used to sign messages on the build queue.
# Both values are base64-encoded. Must match between server and worker.
QUEUE_PRIVATE_KEY=
QUEUE_PUBLIC_KEY=


# ── Shared secrets ───────────────────────────────────────────
# Shared secret between server and worker for authentication.
VELA_SHARED_SECRET=

# Private key used by the server for JWT signing (32 hex chars).
VELA_SERVER_PRIVATE_KEY=


# ── Server / Worker secret binding ──────────────────────────
# These must equal VELA_SHARED_SECRET above — do not change the names,
# they are the env var names Vela expects.
VELA_SECRET=REPLACE_WITH_VELA_SHARED_SECRET
VELA_SERVER_SECRET=REPLACE_WITH_VELA_SHARED_SECRET
